{
  "$schema": "node_modules/wrangler/config-schema.json",
"name": "frontend-app",
  "compatibility_date": "2026-04-25",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/auron-suite",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
